{
  "compilerOptions": {
    "target":           "ES2022",
    "module":           "Node16",
    "moduleResolution": "Node16",
    "rootDir":          "src",
    "outDir":           "dist",
    "strict":           true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "esModuleInterop":  true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck":     true
  },
  "include": ["src/**/*"]
}
